{
  "version": 2,
  "block_at": "high",
  "warn_at": "medium",
  "high_risk_paths": [
    "**/auth/**",
    "**/payments/**",
    "**/billing/**",
    "migrations/**",
    "**/migrations/**"
  ],
  "commit_gate": "warn",
  "layers": {
    "instructions": {
      "mode": "comment",
      "type": "knowledge",
      "notes": "CLAUDE.md §Swiss Cheese governance",
      "holes": "agents drift from instructions in long sessions"
    },
    "lint": {
      "mode": "auto",
      "command": "ruff check .",
      "binary": "ruff",
      "fast": true,
      "holes": "blind to logic and design defects"
    },
    "typecheck": {
      "mode": "auto",
      "command": "mypy src",
      "binary": "mypy",
      "fast": true,
      "holes": "Any/casts bypass; runtime behavior invisible"
    },
    "tests": {
      "mode": "auto",
      "command": "pytest -q",
      "fast": false,
      "timeout": 1800,
      "holes": "only as good as coverage; tests can be weakened to pass"
    },
    "gitleaks": {
      "mode": "auto",
      "command": "gitleaks detect --no-banner",
      "binary": "gitleaks",
      "fast": true,
      "holes": "regex-based; novel secret shapes slip through"
    },
    "guards": {
      "mode": "auto",
      "type": "guards",
      "holes": "regex injection patterns lag new phrasings; slopsquat blind to compromised-but-real packages"
    },
    "review": {
      "mode": "auto",
      "type": "agents",
      "holes": "LLM slices hallucinate; selector can under-cover a lens"
    },
    "docs": {
      "mode": "comment",
      "type": "knowledge",
      "adr_dir": "docs/adr",
      "holes": "docs rot silently between reviews"
    },
    "human-review": {
      "mode": "comment",
      "type": "process",
      "checklist": "docs/review-checklist.md",
      "holes": "fatigue and rubber-stamping"
    }
  },
  "slopsquat_online": false,
  "loop": {
    "order": ["lint", "typecheck", "tests", "guards", "review"],
    "max_iterations": 5
  }
}

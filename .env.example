# Copy this file to .env and fill in the values.
# .env is git-ignored and must never be committed.

# ----- Platform -------------------------------------------------------------
# "gitlab" or "github"
PLATFORM=gitlab

# ----- GitLab ---------------------------------------------------------------
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
GITLAB_PROJECT_ID=12345678

# ----- GitHub ---------------------------------------------------------------
# Only needed when PLATFORM=github (or GitHub Actions CI)
GITHUB_URL=https://api.github.com          # change for GitHub Enterprise Server
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=myorg/myrepo                   # "owner/repo" format

# ----- PostgreSQL + pgvector ------------------------------------------------
DATABASE_URL=postgresql://cr_learner:cr_learner@localhost:5432/cr_learner

# ----- Anthropic (LLM + Voyage embeddings) ----------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Embedding provider: "anthropic" (Voyage API) or "local" (sentence-transformers)
EMBEDDING_PROVIDER=anthropic
EMBEDDING_MODEL=voyage-code-2
EMBEDDING_DIM=1536

# ----- Retrieval ------------------------------------------------------------
RETRIEVAL_TOP_K=5

# ----- Scoring --------------------------------------------------------------
# Time-decay per day; half-life ≈ 139 days at 0.005
TIME_DECAY_LAMBDA=0.005

# Domain authority weights (JSON dict, optional)
# AUTHORITY_WEIGHTS={"kafka": 0.9, "postgresql": 0.8}

# ----- Webhook server -------------------------------------------------------
# Used to verify both GitLab token and GitHub HMAC signature
WEBHOOK_SECRET=change-me-to-a-random-secret
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

# ----- LLM (lesson extraction) -----------------------------------------------
LLM_MODEL=claude-3-5-sonnet-20241022
